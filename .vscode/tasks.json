{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Web Server",
			"type": "shell",
			"command": "python3 -m http.server 58000 --directory build_em",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": ".",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Serving HTTP on .* port ([0-9]+)"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Build Emscripten Test",
			"type": "shell",
			"command": "cd build_em && ninja -f build-${command:cmake.buildType}.ninja test",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}