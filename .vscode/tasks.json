{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Emscripten - Start Web Server",
			"type": "shell",
			"command": "python3 -m http.server 58000 --directory build_em",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": ".",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "Serving HTTP on .* port ([0-9]+)"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Emscripten - Configure",
			"type": "shell",
			"command": "cmake -S . -B build_em -G \"Ninja Multi-Config\" -DCMAKE_BUILD_TYPE=${command:cmake.buildType} -DCMAKE_TOOLCHAIN_FILE=./cmake/Toolchain-emscripten.cmake",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Emscripten - Build All",
			"type": "shell",
			"command": "cd build_em && ninja -f build-${command:cmake.buildType}.ninja all",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Emscripten - Build Examples",
			"type": "shell",
			"command": "cd build_em && ninja -f build-${command:cmake.buildType}.ninja examples/all",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Emscripten - Build Test",
			"type": "shell",
			"command": "cd build_em && ninja -f build-${command:cmake.buildType}.ninja test",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Emscripten - Clean",
			"type": "shell",
			"command": "cmake --build build_em --target clean",
			"problemMatcher": ["$gcc"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}