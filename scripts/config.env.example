# Copy to scripts/config.env and fill in your values.
# Sourced by scripts/ios-install.sh, scripts/ios-launch.sh, scripts/lldb-dap.sh, and scripts/ios_build.py.
# VS Code F5 and CLI invocations share the same source of truth.

# UDID of your iPhone (run `xcrun devicectl list devices`)
IOS_DEVICE=00000000-0000-0000-0000-000000000000

# Apple Developer Team ID (Xcode > Settings > Accounts > Manage Certificates)
AE_APPLE_DEVELOPMENT_TEAM=ABCDEFGHIJ
